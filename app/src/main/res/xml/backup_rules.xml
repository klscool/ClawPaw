<full-backup-content>
    <!-- 排除含认证信息的 SharedPreferences，避免备份泄露 -->
    <exclude domain="sharedpref" path="gateway_prefs.xml"/>
    <exclude domain="sharedpref" path="clawpaw_ssh.xml"/>
    <exclude domain="sharedpref" path="clawpaw_device_identity.xml"/>
</full-backup-content>